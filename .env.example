# === FREE LLM PROVIDERS ===
# Groq: https://console.groq.com/keys (free tier: 14.4K req/day)
GROQ_API_KEY=

# Gemini: https://aistudio.google.com/apikey (free tier: 1500 req/day on Flash)
GEMINI_API_KEY=

# Ollama: local, no key needed. Install: https://ollama.com/download
OLLAMA_HOST=http://localhost:11434

# === MODEL SELECTION ===
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash-exp
# 3B model fits in 4GB VRAM (RTX 3050 Ti)
OLLAMA_MODEL=llama3.2:3b

# === STORAGE (week 3+) ===
POSTGRES_URL=postgresql://competiq:competiq@localhost:5432/competiq
REDIS_URL=redis://localhost:6379

# === OBSERVABILITY (week 4+) ===
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# === RUNTIME ===
LOG_LEVEL=INFO
